{
  "name": "canonry",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev:api": "pnpm --filter @ainyc/aeo-platform-api run dev",
    "dev:worker": "pnpm --filter @ainyc/aeo-platform-worker run dev",
    "dev:web": "pnpm --filter @ainyc/aeo-platform-web run dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v --remove-orphans"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.5.1",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  },
  "engines": {
    "node": ">=20"
  }
}
